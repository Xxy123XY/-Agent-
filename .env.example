OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TOOL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: use a separate provider only for embeddings.
# Leave these empty to reuse OPENAI_API_KEY / OPENAI_BASE_URL.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=embedding-3

OPENAI_TEMPERATURE=0.2
OPENAI_FAST_TEMPERATURE=0
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2

RAG_TOP_K=3
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_RRF_K=60
MEMORY_TOP_K=3
INTERVIEW_QUESTION_COUNT=12
INTERVIEW_BANK_TOP_K=6
INTERVIEW_BANK_MIN_HITS=4
INTERVIEW_BANK_MAX_SIZE=1000
INTERVIEW_BANK_RRF_K=60
INTERVIEW_WEB_SEARCH_K=5
MAX_REVISION_ROUNDS=3
REFLECTION_SCORE_THRESHOLD=7
MAX_REACT_ROUNDS=3
